{
    "manifest_version": 3,
    "name": "DeHype Pro — AI Content Intelligence",
    "version": "2.0.0",
    "description": "Fight clickbait on YouTube & analyze any webpage with AI-powered summaries, smart tags, sentiment analysis, credibility scoring, and intelligent suggestions — powered by Groq AI",
    "permissions": [
        "activeTab",
        "storage",
        "scripting",
        "tabs",
        "contextMenus"
    ],
    "host_permissions": [
        "*://*.youtube.com/*",
        "<all_urls>",
        "https://api.groq.com/*"
    ],
    "action": {
        "default_popup": "popup/popup.html",
        "default_title": "DeHype Pro — AI Content Intelligence"
    },
    "content_scripts": [
        {
            "matches": [
                "*://*.youtube.com/*"
            ],
            "js": [
                "scripts/content.js"
            ],
            "run_at": "document_end"
        },
        {
            "matches": [
                "<all_urls>"
            ],
            "js": [
                "scripts/page-analyzer.js"
            ],
            "css": [
                "scripts/analyzer-panel.css"
            ],
            "run_at": "document_end"
        }
    ],
    "background": {
        "service_worker": "scripts/background.js"
    },
    "web_accessible_resources": [
        {
            "resources": [
                "scripts/injected.js"
            ],
            "matches": [
                "*://*.youtube.com/*"
            ]
        }
    ]
}